   "source": [
    "### Calculating Cosine Similarity with NumPy"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import numpy as np\n",
    "from numpy.linalg import norm\n",
    "\n",
    "# Define vectors\n",
    "u = np.array([0.8, 0.6])\n",
    "v = np.array([0.79, 0.61])\n",
    "\n",
    "# Cosine similarity formula\n",
    "cos_sim = np.dot(u, v) / (norm(u) * norm(v))\n",
    "print(f\"Cosine Similarity: {cos_sim:.4f}\")"
   ]
  }
 ],
